{
	"$schema": "https://docs.renovatebot.com/renovate-schema.json",
	"extends": ["config:recommended"],
	"rangeStrategy": "bump",
	"packageRules": [
		{
			"matchManagers": ["github-actions", "nvm"],
			"rangeStrategy": "replace"
		},
		{
			"matchDepTypes": ["pnpm.overrides"],
			"rangeStrategy": "replace"
		},
		{
			"matchUpdateTypes": ["minor", "patch"],
			"matchCurrentValue": "/^\\^/",
			"groupName": "all non-major caret updates",
			"groupSlug": "caret-minor-patch"
		},
		{
			"matchUpdateTypes": ["patch"],
			"matchCurrentValue": "/^~/",
			"groupName": "all tilde patch updates",
			"groupSlug": "tilde-patch"
		},
		{
			"extends": ["packages:linters"],
			"automerge": true,
			"groupName": null
		}
	]
}
